@require "./_vars.styl"

:root
  --a11y-dt-font-size 14px
  --a11y-dt-line-height 24px
  --a11y-dt-radius 5px
  --a11y-dt-width $calendarWidth
  --a11y-dt-calendar-bg $calendarBackground
  --a11y-dt-calendar-border $calendarBorderColor
  --a11y-dt-month-bg $monthBackground
  --a11y-dt-month-fg $monthForeground
  --a11y-dt-weekdays-bg $weekdaysBackground
  --a11y-dt-weekdays-fg $weekdaysForeground
  --a11y-dt-day-fg $dayForeground
  --a11y-dt-day-disabled-fg rgba(57, 57, 57, 0.42)
  --a11y-dt-day-not-allowed-fg rgba(57, 57, 57, 0.58)
  --a11y-dt-day-hover-bg $dayHoverBackground
  --a11y-dt-today-color $todayColor
  --a11y-dt-selected-bg $selectedDayBackground
  --a11y-dt-selected-fg white
  --a11y-dt-time-height $timeHeight
  --a11y-dt-month-nav-height $monthNavHeight
  --a11y-dt-weekdays-height $weekdaysHeight
  --a11y-dt-shadow 0 3px 13px rgba(0, 0, 0, 0.08)
  --a11y-dt-transition-fast 0.1s
  --a11y-dt-focus-ring 2px solid #0f6cff
  --a11y-dt-focus-ring-offset 2px

@media (prefers-color-scheme: dark)
  :root
    --a11y-dt-calendar-bg #1f232a
    --a11y-dt-calendar-border #3a4250
    --a11y-dt-month-bg #1f232a
    --a11y-dt-month-fg #f2f4f7
    --a11y-dt-weekdays-bg #1f232a
    --a11y-dt-weekdays-fg #cfd5df
    --a11y-dt-day-fg #e7ebf2
    --a11y-dt-day-disabled-fg rgba(199, 211, 235, 0.42)
    --a11y-dt-day-not-allowed-fg rgba(211, 223, 245, 0.62)
    --a11y-dt-day-hover-bg #2e3643
    --a11y-dt-today-color #7fb3ff
    --a11y-dt-selected-bg #4d98ff
    --a11y-dt-selected-fg #ffffff

[data-a11y-datetime-theme="light"]
  --a11y-dt-calendar-bg #ffffff
  --a11y-dt-calendar-border #e6e6e6
  --a11y-dt-month-bg transparent
  --a11y-dt-month-fg rgba(0, 0, 0, 0.9)
  --a11y-dt-weekdays-bg transparent
  --a11y-dt-weekdays-fg rgba(0, 0, 0, 0.54)
  --a11y-dt-day-fg #393939
  --a11y-dt-day-disabled-fg rgba(57, 57, 57, 0.42)
  --a11y-dt-day-not-allowed-fg rgba(57, 57, 57, 0.58)
  --a11y-dt-day-hover-bg #e6e6e6
  --a11y-dt-today-color #959ea9
  --a11y-dt-selected-bg #569ff7
  --a11y-dt-selected-fg #ffffff

[data-a11y-datetime-theme="dark"]
  --a11y-dt-calendar-bg #1f232a
  --a11y-dt-calendar-border #3a4250
  --a11y-dt-month-bg #1f232a
  --a11y-dt-month-fg #f2f4f7
  --a11y-dt-weekdays-bg #1f232a
  --a11y-dt-weekdays-fg #cfd5df
  --a11y-dt-day-fg #e7ebf2
  --a11y-dt-day-disabled-fg rgba(199, 211, 235, 0.42)
  --a11y-dt-day-not-allowed-fg rgba(211, 223, 245, 0.62)
  --a11y-dt-day-hover-bg #2e3643
  --a11y-dt-today-color #7fb3ff
  --a11y-dt-selected-bg #4d98ff
  --a11y-dt-selected-fg #ffffff
  --a11y-dt-focus-ring 2px solid #89b8ff

@media (prefers-reduced-motion: reduce)
  .flatpickr-calendar, .flatpickr-calendar *, .flatpickr-calendar *:before, .flatpickr-calendar *:after
    animation none !important
    transition none !important

.flatpickr-visually-hidden
  position absolute !important
  width 1px
  height 1px
  padding 0
  margin -1px
  overflow hidden
  clip rect(0, 0, 0, 0)
  white-space nowrap
  border 0

.flatpickr-prev-month:focus-visible,
.flatpickr-next-month:focus-visible,
.flatpickr-close-button:focus-visible,
.flatpickr-current-month input.cur-year:focus-visible,
.flatpickr-current-month .flatpickr-monthDropdown-months:focus-visible,
.flatpickr-time input:focus-visible,
.flatpickr-am-pm:focus-visible,
.flatpickr-calendar.is-keyboard-nav .flatpickr-prev-month:focus,
.flatpickr-calendar.is-keyboard-nav .flatpickr-next-month:focus,
.flatpickr-calendar.is-keyboard-nav .flatpickr-close-button:focus,
.flatpickr-calendar.is-keyboard-nav .flatpickr-current-month input.cur-year:focus,
.flatpickr-calendar.is-keyboard-nav .flatpickr-current-month .flatpickr-monthDropdown-months:focus,
.flatpickr-calendar.is-keyboard-nav .flatpickr-time input:focus,
.flatpickr-calendar.is-keyboard-nav .flatpickr-am-pm:focus
  outline var(--a11y-dt-focus-ring)
  outline-offset var(--a11y-dt-focus-ring-offset)

.flatpickr-day:focus-visible
  outline var(--a11y-dt-focus-ring)
  outline-offset var(--a11y-dt-focus-ring-offset)
  z-index 4

.flatpickr-calendar.is-keyboard-nav .flatpickr-day:focus
  outline var(--a11y-dt-focus-ring)
  outline-offset var(--a11y-dt-focus-ring-offset)
  z-index 4

@keyframes fpFadeInDown
  from
    opacity 0
    transform translate3d(0, -20px, 0)

  to
    opacity 1
    transform translate3d(0, 0, 0)


.flatpickr-calendar
  background var(--a11y-dt-calendar-bg)
  opacity 0
  display none
  text-align center
  visibility hidden
  padding 0
  animation none
  direction ltr
  border 0
  font-size var(--a11y-dt-font-size)
  line-height var(--a11y-dt-line-height)
  border-radius var(--a11y-dt-radius)
  position absolute
  width var(--a11y-dt-width)
  box-sizing border-box
  touch-action manipulation

  if $noCalendarBorder is defined
    box-shadow var(--a11y-dt-shadow)

  else
    background var(--a11y-dt-calendar-bg)
    box-shadow 1px 0 0 var(--a11y-dt-calendar-border),
      -1px 0 0 var(--a11y-dt-calendar-border),
      0 1px 0 var(--a11y-dt-calendar-border),
      0 -1px 0 var(--a11y-dt-calendar-border),
      var(--a11y-dt-shadow)


  &.open, &.inline
    opacity 1
    max-height 640px
    visibility visible

  &.open
    display inline-block
    z-index 2147483000

  &.animate.open
    animation fpFadeInDown 300ms $bezier

  &.inline
    display block
    position relative
    top 2px

  &.static
    position absolute
    top calc(100% + 2px)

    &.open
      z-index 999
      display block

  &.multiMonth
    .flatpickr-days .dayContainer:nth-child(n+1)
      & .flatpickr-day.inRange:nth-child(7n+7)
        box-shadow: none !important;

    .flatpickr-days .dayContainer:nth-child(n+2)
      & .flatpickr-day.inRange:nth-child(7n+1)
        box-shadow: -2px 0 0 #e6e6e6, 5px 0 0 #e6e6e6



  .hasWeeks, .hasTime
    .dayContainer
      border-bottom 0
      border-bottom-right-radius 0
      border-bottom-left-radius 0

  if $noCalendarBorder
    .hasWeeks .dayContainer
      border-left 0

  &.hasTime
    .flatpickr-time
      height var(--a11y-dt-time-height)
      border-top 1px solid var(--a11y-dt-calendar-border)

    if $noCalendarBorder is defined
      .flatpickr-innerContainer
        border-bottom 0

      .flatpickr-time
        border 1px solid var(--a11y-dt-calendar-border)

  &.noCalendar.hasTime
    .flatpickr-time
      height auto

  &:before, &:after
    position absolute
    display block
    pointer-events none
    border solid transparent
    content ''
    height 0
    width 0
    left 22px

  &.rightMost, &.arrowRight
    &:before, &:after
      left auto
      right 22px

  &.arrowCenter
    &:before, &:after
      left 50%
      right 50%

  &:before
    border-width 5px
    margin 0 -5px

  &:after
    border-width 4px
    margin 0 -4px

  &.arrowTop
    &:before, &:after
      bottom 100%
    &:before
      border-bottom-color var(--a11y-dt-calendar-border)
    &:after
      if $noCalendarBorder is defined
        border-bottom-color $monthBackground
      else
        border-bottom-color var(--a11y-dt-calendar-bg)

  &.arrowBottom
    &:before, &:after
      top 100%
    &:before
      border-top-color var(--a11y-dt-calendar-border)
    &:after
      if $noCalendarBorder is defined
        border-top-color $monthBackground
      else
        border-top-color var(--a11y-dt-calendar-bg)

  &:focus
    outline 0

.flatpickr-wrapper
  position relative
  display inline-block

.flatpickr-close-button
  border 1px solid var(--a11y-dt-calendar-border)
  background var(--a11y-dt-calendar-bg)
  color var(--a11y-dt-month-fg)
  border-radius 6px
  width 28px
  height 28px
  display inline-flex
  align-items center
  justify-content center
  cursor pointer
  transition background var(--a11y-dt-transition-fast), transform var(--a11y-dt-transition-fast)

  &:hover
    background var(--a11y-dt-day-hover-bg)

  .flatpickr-close-icon
    width 14px
    height 14px
    display block

    path
      fill currentColor

.flatpickr-titlebar
  display flex
  align-items center
  justify-content space-between
  height 2.5rem
  padding 0.25rem 0.4rem 0.25rem 0.75rem
  border-bottom 1px solid var(--a11y-dt-calendar-border)
  background var(--a11y-dt-month-bg)
  border-top-left-radius var(--a11y-dt-radius)
  border-top-right-radius var(--a11y-dt-radius)

  .flatpickr-title
    font-size 1rem
    font-weight 600
    color var(--a11y-dt-month-fg)
    white-space nowrap
    overflow hidden
    text-overflow ellipsis
    text-align left

  .flatpickr-close-button
    width 2rem
    min-width 2rem
    max-width 2rem
    height 2rem
    border-radius 999px
    border 1px solid var(--a11y-dt-calendar-border)
    padding 0
    margin 0

.flatpickr-months
  display flex
  align-items stretch
  background var(--a11y-dt-month-bg)
  border-top 1px solid var(--a11y-dt-calendar-border)
  border-bottom 0
  position relative
  z-index 5

.flatpickr-titlebar + .flatpickr-months
  border-top 0


.flatpickr-months
  .flatpickr-month
    if $noCalendarBorder is defined
      border-radius 5px 5px 0 0
    background transparent
    color var(--a11y-dt-month-fg)
    fill var(--a11y-dt-month-fg)
    height var(--a11y-dt-month-nav-height)
    line-height 1
    text-align center
    position relative
    user-select none
    // Keep month dropdowns from being clipped when opened.
    overflow visible
    flex 1

  .flatpickr-prev-month, .flatpickr-next-month
    user-select none
    text-decoration none
    cursor pointer
    background transparent
    border 0
    position relative
    flex 0 0 2.75rem
    width 2.75rem
    height var(--a11y-dt-month-nav-height)
    padding 0
    display inline-flex
    align-items center
    justify-content center
    z-index 1
    color var(--a11y-dt-month-fg)
    fill var(--a11y-dt-month-fg)

    &.flatpickr-prev-month, &.flatpickr-next-month
      border 0

    &.flatpickr-disabled
      display none

    i
      position relative

    &:hover
      color var(--a11y-dt-today-color)
      svg
        if $arrow_hover_color is defined
          fill $arrow_hover_color

        else
          fill var(--a11y-dt-today-color)

    svg
      width 14px
      height 14px
      display block
      fill var(--a11y-dt-month-fg)

      path
        transition fill var(--a11y-dt-transition-fast)
        fill inherit


.numInputWrapper
  position relative
  height auto

  input, span
    display inline-block

  input
    width 100%
    &::-ms-clear
      display none

    &::-webkit-outer-spin-button, &::-webkit-inner-spin-button
      margin 0
      -webkit-appearance none

  span
    position absolute
    right 0
    width 14px
    padding 0 4px 0 2px
    height 50%
    line-height 50%
    opacity 0
    cursor pointer
    border 1px solid var(--a11y-dt-calendar-border)
    box-sizing border-box

    &:hover
      background var(--a11y-dt-day-hover-bg)

    &:active
      background var(--a11y-dt-selected-bg)

    &:after
      display block
      content ""
      position absolute

    &.arrowUp
      top 0
      border-bottom 0

      &:after
        border-left 4px solid transparent
        border-right 4px solid transparent
        border-bottom 4px solid var(--a11y-dt-day-fg)
        top 26%

    &.arrowDown
      top 50%

      &:after
        border-left 4px solid transparent
        border-right 4px solid transparent
        border-top 4px solid var(--a11y-dt-day-fg)
        top 40%

    svg
      width inherit
      height auto
      path
        fill alpha($monthForeground, 0.5)

  &:hover
    background var(--a11y-dt-day-hover-bg)

    span
      opacity 1


.flatpickr-current-month
  font-size 135%
  line-height inherit
  font-weight 300
  color inherit
  position absolute
  width 82%
  left 12.5%
  padding (0.22*$monthNavHeight) 0 0 0
  line-height 1
  height $monthNavHeight
  display grid
  grid-auto-flow column
  grid-auto-columns max-content
  align-items center
  justify-content center
  column-gap 0.35rem
  text-align center
  white-space nowrap
  transform translate3d(0px, 0px, 0px)
  z-index 6

  span.cur-month
    font-family inherit
    font-weight 700
    color inherit
    display inline-block
    margin-left 0.5ch
    padding 0

    &:hover
      background: alpha($invertedBg, 0.05)


  .numInputWrapper
    width 6ch
    width unquote("7ch\0")
    display inline-flex
    flex 0 0 auto

    span.arrowUp:after
      border-bottom-color $monthForeground

    span.arrowDown:after
      border-top-color $monthForeground

  input.cur-year
    background transparent
    box-sizing border-box
    color inherit
    cursor text
    padding 0 0 0 0.5ch
    margin 0
    display inline-block
    min-width 4.5ch
    font-size inherit
    font-family inherit
    font-weight 300
    line-height inherit
    height auto
    border 0
    border-radius 0
    vertical-align initial
    -webkit-appearance textfield
    -moz-appearance textfield
    appearance textfield

    &:focus:not(:focus-visible)
      outline 0

    &[disabled], &[disabled]:hover
      font-size 100%
      color alpha($monthForeground, 0.5)
      background transparent
      pointer-events none

  .flatpickr-monthDropdown-months
    background transparent
    border: none
    border-radius: 0.35rem
    color: inherit
    cursor: pointer
    font-size: inherit
    font-family: inherit
    font-weight: 300
    height: auto
    line-height: inherit
    margin: -1px 0 0 0
    outline: none
    padding: 0 0.25rem 0 0.5ch
    position: relative
    vertical-align: initial
    box-sizing: border-box
    display inline-flex
    align-items center
    -webkit-appearance: none
    -moz-appearance: none
    appearance: none
    width: auto
    min-width: 10ch
    max-width: calc(100% - 4.75ch)
    flex: 0 0 auto

    &:focus:not(:focus-visible), &:active:not(:focus-visible)
      outline: none

    &:hover
      background var(--a11y-dt-day-hover-bg)

  .flatpickr-monthDropdown
    position relative
    display inline-flex
    align-items center

  .flatpickr-monthPicker
    display none
    position absolute
    top calc(100% + 0.25rem)
    left 0
    min-width 10rem
    max-height 14rem
    overflow auto
    padding 0.25rem
    border 1px solid var(--a11y-dt-border)
    border-radius 0.5rem
    background var(--a11y-dt-day-bg)
    box-shadow 0 10px 30px rgba(0, 0, 0, 0.22)
    z-index 10

    &.open
      display block

  .flatpickr-monthPicker-option
    width 100%
    border 0
    border-radius 0.35rem
    background transparent
    color var(--a11y-dt-day-fg)
    text-align left
    font inherit
    padding 0.35rem 0.5rem
    cursor pointer

    &:hover
      background var(--a11y-dt-day-hover-bg)

    &.is-selected
      background var(--a11y-dt-selected-bg)
      color var(--a11y-dt-selected-fg)

    &:focus-visible
      outline var(--a11y-dt-focus-ring)
      outline-offset -1px

.flatpickr-weekdays
  background var(--a11y-dt-month-bg)
  text-align center
  overflow hidden
  position relative
  z-index 1
  width 100%
  display flex
  align-items center
  height auto
  min-height var(--a11y-dt-weekdays-height)
  padding 0.2rem 0 0.3rem
  border-bottom 1px solid var(--a11y-dt-calendar-border)

  .flatpickr-weekdaycontainer
    display flex
    flex 1



span.flatpickr-weekday
  cursor default
  font-size 90%
  background transparent
  color var(--a11y-dt-weekdays-fg)
  line-height 1.2
  margin 0
  text-align center
  display block
  flex 1
  font-weight 700


.dayContainer, .flatpickr-weeks
  padding 0

.flatpickr-days
  position: relative;
  overflow: hidden;
  display flex
  align-items: flex-start;
  width $daysWidth
  background var(--a11y-dt-calendar-bg)

  &:focus
    outline 0

  if $noCalendarBorder is defined
    border-left 1px solid $calendarBorderColor
    border-right 1px solid $calendarBorderColor


.dayContainer
  padding 0
  outline 0
  text-align left
  width ($daysWidth)
  min-width ($daysWidth)
  max-width ($daysWidth)
  box-sizing border-box
  display inline-block
  display -ms-flexbox
  display flex
  -ms-flex-wrap wrap
  flex-wrap wrap
  -ms-flex-pack: justify
  justify-content space-around
  transform: translate3d(0px, 0px, 0px);
  opacity 1

  & + .dayContainer
    box-shadow: -1px 0 0 $calendarBorderColor;


.flatpickr-day
  background none
  border 1px solid transparent
  border-radius 150px
  box-sizing border-box
  color var(--a11y-dt-day-fg)
  cursor pointer

  font-weight 400
  width 14.2857143%
  flex-basis 14.2857143%
  max-width $daySize
  height $daySize
  line-height $daySize
  margin 0

  display inline-block
  position relative
  justify-content center
  text-align center

  &, &.prevMonthDay, &.nextMonthDay
    &.inRange, &.today.inRange, &:hover, &:focus
      cursor pointer
      outline 0
      background var(--a11y-dt-day-hover-bg)
      border-color var(--a11y-dt-day-hover-bg)


  &.today
    border-color var(--a11y-dt-today-color)

    &:hover, &:focus
      border-color var(--a11y-dt-today-color)
      background var(--a11y-dt-today-color)
      if $today_fg_color is defined
        color $today_fg_color
      else
        color white

  &.selected, &.startRange, &.endRange
    &, &.inRange, &:focus, &:hover, &.prevMonthDay, &.nextMonthDay
      background var(--a11y-dt-selected-bg)
      box-shadow none

      if $selectedDayForeground is defined
        color $selectedDayForeground
      else
        color var(--a11y-dt-selected-fg)

      border-color var(--a11y-dt-selected-bg)

    &.startRange
      border-radius 50px 0 0 50px
      //box-shadow:  (2.5*$dayMargin) 0 0 $selectedDayBackground

    &.endRange
      border-radius 0 50px 50px 0

    // Avoid adding extra fill because it overflows in multimonth mode
    &.startRange + .endRange:not(:nth-child(7n+1))
      box-shadow: (-5*$dayMargin) 0 0 $selectedDayBackground

    &.startRange.endRange
      border-radius 50px

  &.inRange
    border-radius 0
    box-shadow: (-2.5*$dayMargin) 0 0 $dayHoverBackground, (2.5*$dayMargin) 0 0 $dayHoverBackground

  &.flatpickr-disabled, &.flatpickr-disabled:hover,
  &.prevMonthDay, &.nextMonthDay,
  &.notAllowed, &.notAllowed.prevMonthDay, &.notAllowed.nextMonthDay
    color var(--a11y-dt-day-disabled-fg)
    background transparent

    if $disabled_border_color is defined
      border-color $disabled_border_color

    else
      border-color transparent
    cursor default

  &.flatpickr-disabled, &.flatpickr-disabled:hover
    cursor not-allowed
    color var(--a11y-dt-day-not-allowed-fg)

  &.week.selected
    border-radius 0
    box-shadow: (-2.5*$dayMargin) 0 0 $selectedDayBackground,
      (2.5*$dayMargin) 0 0 $selectedDayBackground

  &.hidden
    visibility hidden

.rangeMode .flatpickr-day
  margin-top 1px

.flatpickr-weekwrapper
  float left

  .flatpickr-weeks
    padding 0 12px
    if $noCalendarBorder is defined
      border-left 1px solid $calendarBorderColor
    else
      box-shadow 1px 0 0 $calendarBorderColor

  .flatpickr-weekday
    float none
    width 100%
    display flex
    align-items center
    justify-content center
    min-height var(--a11y-dt-weekdays-height)
    padding 0.2rem 0 0.3rem
    line-height 1.2
    margin 0
    border-bottom 1px solid var(--a11y-dt-calendar-border)
    background var(--a11y-dt-month-bg)
    color var(--a11y-dt-weekdays-fg)

  span.flatpickr-day
    &, &:hover
      display block
      width 100%
      max-width none
      color var(--a11y-dt-day-disabled-fg)
      background transparent
      cursor default
      border none


.flatpickr-innerContainer
  display block
  display flex
  box-sizing border-box
  overflow: hidden;

  if $noCalendarBorder is defined
    background $calendarBackground
    border-bottom 1px solid $calendarBorderColor


.flatpickr-rContainer
  display inline-block
  padding 0
  box-sizing border-box


.flatpickr-time
  text-align center
  outline 0
  display block
  height 0 // hide initially
  line-height var(--a11y-dt-time-height)
  max-height var(--a11y-dt-time-height)
  box-sizing border-box
  overflow hidden
  display flex

  if $noCalendarBorder is defined
    background $calendarBackground
    border-radius 0 0 5px  5px

  &:after
    content ""
    display table
    clear both

  .numInputWrapper
    flex 1
    width 40%
    height $timeHeight
    float left

    span.arrowUp:after
      border-bottom-color $dayForeground

    span.arrowDown:after
      border-top-color $dayForeground

  &.hasSeconds .numInputWrapper
    width 26%

  &.time24hr .numInputWrapper
    width 49%

  input
    background transparent
    box-shadow none
    border 0
    border-radius 0
    text-align center
    margin 0
    padding 0
    height inherit
    line-height inherit
    color var(--a11y-dt-day-fg)
    font-size 14px
    position relative
    box-sizing border-box
    -webkit-appearance textfield
    -moz-appearance textfield
    appearance textfield


    &.flatpickr-hour
      font-weight bold

    &.flatpickr-minute, &.flatpickr-second
      font-weight 400

    &:focus
      outline 0
      border 0

  .flatpickr-time-separator, .flatpickr-am-pm
    height inherit
    float left
    line-height inherit
    color var(--a11y-dt-day-fg)
    font-weight bold
    width 2%
    user-select none
    align-self center

  .flatpickr-am-pm
    outline 0
    width 18%
    cursor pointer
    text-align center
    font-weight 400

  input, .flatpickr-am-pm
    &:hover, &:focus
      background var(--a11y-dt-day-hover-bg)

.flatpickr-input[readonly]
  cursor pointer
